  "description":"GameMaker bindings for the Odin gmtextedit.dll text editing helpers.",
  "exportToGame":true,
  "extensionVersion":"1.0.0",
  "files":[
    {"$GMExtensionFile":"v1","%Name":"gmtextedit.dll","constants":[],"copyToTargets":-1,"filename":"gmtextedit.dll","final":"","functions":[
        {"$GMExtensionFunction":"","%Name":"gmte_create","argCount":2,"args":[1,1,],"documentation":"Creates a text editor state for id with initial_text. If id already exists, its text and edit state are reset. Returns 1 on success, 0 on failure.","externalName":"gmte_create","help":"gmte_create(id, initial_text)","hidden":false,"kind":11,"name":"gmte_create","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_destroy","argCount":1,"args":[1,],"documentation":"Destroys the editor state stored under id and releases its memory. Returns 1 when an editor was destroyed, 0 when id is invalid or missing.","externalName":"gmte_destroy","help":"gmte_destroy(id)","hidden":false,"kind":11,"name":"gmte_destroy","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_destroy_all","argCount":0,"args":[],"documentation":"Destroys every active editor state and clears the editor registry. Returns 1.","externalName":"gmte_destroy_all","help":"gmte_destroy_all()","hidden":false,"kind":11,"name":"gmte_destroy_all","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_exists","argCount":1,"args":[1,],"documentation":"Returns 1 if an editor exists for id, otherwise returns 0 and updates the last status/error.","externalName":"gmte_exists","help":"gmte_exists(id)","hidden":false,"kind":11,"name":"gmte_exists","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_set_text","argCount":2,"args":[1,1,],"documentation":"Replaces the editor text for id, resets the text edit state around the new text, and returns the updated text.","externalName":"gmte_set_text","help":"gmte_set_text(id, text)","hidden":false,"kind":11,"name":"gmte_set_text","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":1,},
        {"$GMExtensionFunction":"","%Name":"gmte_get_text","argCount":1,"args":[1,],"documentation":"Returns the current text stored in the editor for id. Returns an empty string if id is invalid or missing.","externalName":"gmte_get_text","help":"gmte_get_text(id)","hidden":false,"kind":11,"name":"gmte_get_text","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":1,},
        {"$GMExtensionFunction":"","%Name":"gmte_input_text","argCount":2,"args":[1,1,],"documentation":"Inserts text at the current caret, replacing the active selection if one exists, and returns the updated editor text.","externalName":"gmte_input_text","help":"gmte_input_text(id, text)","hidden":false,"kind":11,"name":"gmte_input_text","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":1,},
        {"$GMExtensionFunction":"","%Name":"gmte_command","argCount":2,"args":[1,2,],"documentation":"Runs a text edit command on the editor for id and returns the updated text. Command values mirror the GMTE_Command enum.","externalName":"gmte_command","help":"gmte_command(id, command)","hidden":false,"kind":11,"name":"gmte_command","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":1,},
        {"$GMExtensionFunction":"","%Name":"gmte_set_selection","argCount":3,"args":[1,2,2,],"documentation":"Sets the editor selection using byte indices head and tail, clamps indices to valid UTF-8 boundaries, and returns the current text.","externalName":"gmte_set_selection","help":"gmte_set_selection(id, head, tail)","hidden":false,"kind":11,"name":"gmte_set_selection","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":1,},
        {"$GMExtensionFunction":"","%Name":"gmte_get_caret","argCount":1,"args":[1,],"documentation":"Returns the current caret byte index for id. Returns -1 if id is invalid or missing.","externalName":"gmte_get_caret","help":"gmte_get_caret(id)","hidden":false,"kind":11,"name":"gmte_get_caret","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_get_anchor","argCount":1,"args":[1,],"documentation":"Returns the current selection anchor byte index for id. Returns -1 if id is invalid or missing.","externalName":"gmte_get_anchor","help":"gmte_get_anchor(id)","hidden":false,"kind":11,"name":"gmte_get_anchor","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_get_selection_start","argCount":1,"args":[1,],"documentation":"Returns the lower byte index of the current selection for id. Returns -1 if id is invalid or missing.","externalName":"gmte_get_selection_start","help":"gmte_get_selection_start(id)","hidden":false,"kind":11,"name":"gmte_get_selection_start","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_get_selection_end","argCount":1,"args":[1,],"documentation":"Returns the upper byte index of the current selection for id. Returns -1 if id is invalid or missing.","externalName":"gmte_get_selection_end","help":"gmte_get_selection_end(id)","hidden":false,"kind":11,"name":"gmte_get_selection_end","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_get_text_length","argCount":1,"args":[1,],"documentation":"Returns the editor text length in bytes. Returns -1 if id is invalid or missing.","externalName":"gmte_get_text_length","help":"gmte_get_text_length(id)","hidden":false,"kind":11,"name":"gmte_get_text_length","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_get_selected_text","argCount":1,"args":[1,],"documentation":"Returns the currently selected text for id, or an empty string when there is no selection or the editor is missing.","externalName":"gmte_get_selected_text","help":"gmte_get_selected_text(id)","hidden":false,"kind":11,"name":"gmte_get_selected_text","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":1,},
        {"$GMExtensionFunction":"","%Name":"gmte_set_translate_by_grapheme","argCount":2,"args":[1,2,],"documentation":"Enables or disables grapheme-aware left/right caret movement for id. Pass a nonzero enabled value to turn it on.","externalName":"gmte_set_translate_by_grapheme","help":"gmte_set_translate_by_grapheme(id, enabled)","hidden":false,"kind":11,"name":"gmte_set_translate_by_grapheme","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_clipboard_set","argCount":1,"args":[1,],"documentation":"Stores text in the extension-managed clipboard buffer used by copy, cut, and paste commands. Returns 1.","externalName":"gmte_clipboard_set","help":"gmte_clipboard_set(text)","hidden":false,"kind":11,"name":"gmte_clipboard_set","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_clipboard_get","argCount":0,"args":[],"documentation":"Returns the current text from the extension-managed clipboard buffer.","externalName":"gmte_clipboard_get","help":"gmte_clipboard_get()","hidden":false,"kind":11,"name":"gmte_clipboard_get","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":1,},
        {"$GMExtensionFunction":"","%Name":"gmte_last_status","argCount":0,"args":[],"documentation":"Returns the status code from the most recent extension call. Values mirror the GMTE_Status enum.","externalName":"gmte_last_status","help":"gmte_last_status()","hidden":false,"kind":11,"name":"gmte_last_status","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"gmte_last_error","argCount":0,"args":[],"documentation":"Returns the most recent extension error message, or an empty string when the last operation succeeded.","externalName":"gmte_last_error","help":"gmte_last_error()","hidden":false,"kind":11,"name":"gmte_last_error","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":1,},
      ],"init":"","kind":1,"name":"gmtextedit.dll","origname":"extensions\\gmtextedit.dll","ProxyFiles":[],"resourceType":"GMExtensionFile","resourceVersion":"2.0","uncompress":false,"usesRunnerInterface":false,},
